<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <title>Malerbetrieb Gumbel – Qualität aus Meisterhand seit 1924</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="styles.css" />
</head>
<body>
  <!-- Navigation -->
  <header class="header">
    <div class="container header-inner">
      <a href="#top" class="logo">
        <img src="https://www.malerbetrieb-gumbel.de/wordpress/wp-content/uploads/2018/02/cropped-Logo_Gumbel.png"
             alt="Malerbetrieb Gumbel Logo">
      </a>
      <nav class="nav">
        <a href="#leistungen">Leistungen</a>
        <a href="#referenzen">Referenzen</a>
        <a href="#ueber-uns">Über uns</a>
        <a href="#kontakt" class="nav-cta">Kontakt</a>
      </nav>
      <button class="nav-toggle" aria-label="Menü öffnen">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <!-- Hero -->
  <section class="hero" id="top">
    <div class="container hero-inner">
      <div class="hero-text">
        <h1>Malerbetrieb Gumbel</h1>
        <p class="hero-subtitle">Qualität aus Meisterhand – seit 1924 in Mannheim</p>
        <p>Wir gestalten Innen- und Außenbereiche mit Liebe zum Detail, hochwertigen Materialien und zuverlässiger Ausführung.</p>
        <div class="hero-actions">
          <a href="#kontakt" class="btn btn-primary">Jetzt Angebot anfragen</a>
          <a href="#leistungen" class="btn btn-outline">Leistungen ansehen</a>
        </div>
        <div class="hero-badges">
          <span>✔ Familienbetrieb seit 1924</span>
          <span>✔ Meisterbetrieb</span>
          <span>✔ Persönliche Beratung</span>
        </div>
      </div>
      <div class="hero-image">
        <!-- Beispielbild – eigenes Bild verwenden -->
        <img src="https://www.malerbetrieb-gumbel.de/wp-content/uploads/2018/02/innen-colorful-1.png"
             alt="Innenraumgestaltung">
      </div>
    </div>
  </section>

  <!-- Leistungen -->
  <section class="section" id="leistungen">
    <div class="container">
      <h2>Unsere Leistungen</h2>
      <p class="section-intro">
        Ob Innen- oder Außenbereich – wir bieten Ihnen ein breites Spektrum an Maler- und Lackierarbeiten
        für Privatkunden, Unternehmen und Hausverwaltungen.
      </p>
      <div class="cards">
        <article class="card">
          <div class="card-icon">
            <img src="https://www.malerbetrieb-gumbel.de/wp-content/uploads/2018/02/innen-colorful-1.png" alt="Innenbereich">
          </div>
          <h3>Innenbereich</h3>
          <ul>
            <li>Wand- und Deckenanstriche</li>
            <li>Spachtel- und Putztechniken</li>
            <li>Tapeten und Wandbeläge</li>
            <li>Lackierarbeiten an Türen &amp; Zargen</li>
          </ul>
          <a href="https://www.malerbetrieb-gumbel.de/leistungen/#innenbereich" class="card-link">
            Mehr zum Innenbereich
          </a>
        </article>

        <article class="card">
          <div class="card-icon">
            <img src="https://www.malerbetrieb-gumbel.de/wp-content/uploads/2018/02/au%C3%9Fen-colorful.png" alt="Außenbereich">
          </div>
          <h3>Außenbereich</h3>
          <ul>
            <li>Fassadengestaltung &amp; -anstriche</li>
            <li>Wärmedämmverbundsysteme (WDVS)</li>
            <li>Holzschutzanstriche</li>
            <li>Balkon- und Geländerbeschichtungen</li>
          </ul>
          <a href="https://www.malerbetrieb-gumbel.de/leistungen/#aussenbereich" class="card-link">
            Mehr zum Außenbereich
          </a>
        </article>

        <article class="card">
          <div class="card-icon">
            <img src="https://www.malerbetrieb-gumbel.de/wp-content/uploads/2018/02/icon-3.png" alt="Beratung & Service">
          </div>
          <h3>Beratung &amp; Service</h3>
          <ul>
            <li>Individuelle Farbberatung</li>
            <li>Termintreue &amp; saubere Ausführung</li>
            <li>Angebote zum Festpreis</li>
            <li>Koordination mit anderen Gewerken</li>
          </ul>
          <a href="#kontakt" class="card-link">
            Termin vereinbaren
          </a>
        </article>
      </div>
    </div>
  </section>

  <!-- Referenzen -->
  <section class="section section-alt" id="referenzen">
    <div class="container">
      <h2>Referenzen</h2>
      <p class="section-intro">
        Eine Auswahl unserer Arbeiten aus Mannheim und Umgebung.
      </p>
      <div class="grid-3">
        <div class="ref-card">
          <h3>Privathaus – Innenrenovierung</h3>
          <p>Komplette Neugestaltung von Wohn- und Schlafräumen mit modernen Farbakzenten.</p>
        </div>
        <div class="ref-card">
          <h3>Mehrfamilienhaus – Fassade</h3>
          <p>Fassadensanierung inkl. Wärmedämmung und langlebigem Fassadenanstrich.</p>
        </div>
        <div class="ref-card">
          <h3>Geschäftsräume</h3>
          <p>Repräsentative Gestaltung von Büro- und Verkaufsflächen.</p>
        </div>
      </div>
      <a href="https://www.malerbetrieb-gumbel.de/leistungen/referenzen/" class="btn btn-outline">
        Weitere Referenzen ansehen
      </a>
    </div>
  </section>

  <!-- Über uns -->
  <section class="section" id="ueber-uns">
    <div class="container about">
      <div class="about-text">
        <h2>Über uns</h2>
        <p>
          Der Malerbetrieb Gumbel ist ein traditionsreicher Familienbetrieb in Mannheim-Friedrichsfeld –
          seit 1924 stehen wir für zuverlässige Handwerksarbeit und zufriedene Kunden.
        </p>
        <p>
          Als Meisterbetrieb legen wir großen Wert auf Qualität, saubere Ausführung und eine
          persönliche Betreuung von der ersten Beratung bis zur fertigen Übergabe.
        </p>
        <ul class="about-list">
          <li>Meisterbetrieb mit langjähriger Erfahrung</li>
          <li>Regionale Verbundenheit in Mannheim und Umgebung</li>
          <li>Faire, transparente Angebote</li>
        </ul>
      </div>
      <div class="about-facts">
        <div class="fact">
          <span class="fact-number">1924</span>
          <span class="fact-label">Gründungsjahr</span>
        </div>
        <div class="fact">
          <span class="fact-number">100+</span>
          <span class="fact-label">Jahre Erfahrung</span>
        </div>
        <div class="fact">
          <span class="fact-number">Region</span>
          <span class="fact-label">Mannheim & Umgebung</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Kontakt -->
  <section class="section section-alt" id="kontakt">
    <div class="container contact">
      <div class="contact-info">
        <h2>Kontakt</h2>
        <p>Sie planen ein Projekt oder haben Fragen? Rufen Sie uns an oder schreiben Sie uns eine E‑Mail.</p>
        <ul class="contact-list">
          <li><strong>Malerbetrieb Gumbel</strong></li>
          <li>Hauptstraße 61</li>
          <li>68259 Mannheim</li>
          <li>Tel: <a href="tel:+49621795719">0621 / 79 57 19</a></li>
          <li>Fax: 0621 / 430 322 9</li>
          <li>E-Mail: <a href="mailto:info@malerbetrieb-gumbel.de">info@malerbetrieb-gumbel.de</a></li>
        </ul>
        <a href="https://www.google.de/maps?q=Malerbetrieb+Gumbel+Hauptstra%C3%9Fe+61+68259+Mannheim"
           class="btn btn-primary" target="_blank" rel="noopener">
          Route planen
        </a>
      </div>
      <div class="contact-form">
        <!-- Wenn du ein echtes Formular willst, hier mit Contact Form 7 o.ä. ersetzen -->
        <form>
          <div class="form-row">
            <label for="name">Name*</label>
            <input type="text" id="name" placeholder="Ihr Name" required>
          </div>
          <div class="form-row">
            <label for="email">E-Mail*</label>
            <input type="email" id="email" placeholder="Ihre E-Mail-Adresse" required>
          </div>
          <div class="form-row">
            <label for="message">Nachricht*</label>
            <textarea id="message" rows="4" placeholder="Wie können wir Ihnen helfen?" required></textarea>
          </div>
          <p class="form-hint">
            Mit dem Absenden Ihrer Anfrage erklären Sie sich mit der Verarbeitung Ihrer Daten gemäß unserer
            <a href="/datenschutz/" target="_blank" rel="noopener">Datenschutzerklärung</a> einverstanden.
          </p>
          <button type="submit" class="btn btn-primary">Nachricht senden</button>
        </form>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container footer-inner">
      <p>© Malerbetrieb Gumbel – Qualität aus Meisterhand</p>
      <div class="footer-links">
        <a href="/kontakt/">Kontakt</a>
        <a href="/impressum/">Impressum</a>
        <a href="/datenschutz/">Datenschutz</a>
      </div>
    </div>
  </footer>

